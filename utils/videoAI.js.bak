'use strict';

const fs       = require('fs');
const path     = require('path');
const fetch    = require('node-fetch');

// ═══════════════════════════════════════════
// GEMINI VISION — rasm tahlili
// ═══════════════════════════════════════════

var GEMINI_KEYS = [];

function initGemini() {
  var raw = process.env.GEMINI_API_KEY || '';
  GEMINI_KEYS = raw.split(',').map(function(k) { return k.trim(); }).filter(Boolean);
}

function getGeminiKey() {
  if (!GEMINI_KEYS.length) initGemini();
  if (!GEMINI_KEYS.length) throw new Error('GEMINI_API_KEY yo\'q');
  return GEMINI_KEYS[Math.floor(Math.random() * GEMINI_KEYS.length)];
}

// ─────────────────────────────────────────
// Rasmni tahlil qilib effekt rejasi qaytaradi
// ─────────────────────────────────────────
async function analyzeImageForVideo(imagePath, userPrompt, lang) {
  var key = getGeminiKey();
  var url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=' + key;

  var imgData   = fs.readFileSync(imagePath);
  var base64Img = imgData.toString('base64');
  var mimeType  = imagePath.toLowerCase().endsWith('.png') ? 'image/png' : 'image/jpeg';

  var langHint = lang === 'uz' ? 'uzbek' : lang === 'ru' ? 'russian' : 'english';

  var systemPrompt = `You are a professional video director AI. Analyze the image and create a video effect plan.
Return ONLY a valid JSON object (no markdown, no extra text) with this exact structure:
{
  "style": "nostalgic|dramatic|warm|cool|cinema|happy|memorial",
  "effects": ["ken_burns", "vignette"],
  "zoom": "in|out",
  "pan": "center|left|right|up|down",
  "duration": 10,
  "text": "",
  "text_position": "bottom",
  "description": "brief description in ${langHint}",
  "mood": "brief mood in ${langHint}"
}

Rules:
- style must be one of: nostalgic, dramatic, warm, cool, cinema, happy, memorial
- effects array can include: ken_burns, vignette, grain, letterbox, parallax, heartbeat
- zoom: "in" or "out"
- pan: center, left, right, up, down
- duration: 8-15 seconds based on content
- text: empty string unless user asked for specific text
- Always include "ken_burns" or "parallax" in effects
- Always include "vignette" in effects
- For old/family photos: style=nostalgic, add grain
- For portraits: heartbeat effect, zoom in slowly
- For landscapes: parallax, zoom out
- For celebrations: style=happy, warm, no grain`;

  var userContent = userPrompt
    ? `Create a video for this image. User request: "${userPrompt}"`
    : 'Create the best possible video for this image based on its content and mood.';

  var body = {
    system_instruction: { parts: [{ text: systemPrompt }] },
    contents: [{
      role: 'user',
      parts: [
        { inline_data: { mime_type: mimeType, data: base64Img } },
        { text: userContent }
      ]
    }],
    generationConfig: {
      maxOutputTokens: 512,
      temperature:     0.4
    }
  };

  try {
    var res = await fetch(url, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(body),
      timeout: 30000
    });

    if (!res.ok) {
      var errText = await res.text();
      throw new Error('Gemini API xato: ' + res.status + ' ' + errText.slice(0, 200));
    }

    var data      = await res.json();
    var candidate = data.candidates && data.candidates[0];
    if (!candidate) throw new Error('Gemini javob bermadi');

    var raw = candidate.content && candidate.content.parts &&
              candidate.content.parts[0] && candidate.content.parts[0].text || '';

    // JSON ni ajratib olamiz
    var jsonMatch = raw.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error('JSON topilmadi: ' + raw.slice(0, 200));

    var plan = JSON.parse(jsonMatch[0]);

    // Validatsiya va default qiymatlar
    var validStyles = ['nostalgic','dramatic','warm','cool','cinema','happy','memorial'];
    if (!validStyles.includes(plan.style)) plan.style = 'warm';
    if (!Array.isArray(plan.effects) || !plan.effects.length) plan.effects = ['ken_burns','vignette'];
    if (!['in','out'].includes(plan.zoom)) plan.zoom = 'in';
    if (!['center','left','right','up','down'].includes(plan.pan)) plan.pan = 'center';
    plan.duration    = Math.min(15, Math.max(8, parseInt(plan.duration) || 10));
    plan.text        = plan.text || '';
    plan.text_position = plan.text_position || 'bottom';
    plan.description = plan.description || '';
    plan.mood        = plan.mood || '';

    return { ok: true, plan: plan };

  } catch (e) {
    console.error('[VideoAI] Gemini xato:', e.message);
    // Fallback — standart reja
    return {
      ok:   true,
      plan: getDefaultPlan(userPrompt),
      fallback: true
    };
  }
}

// ─────────────────────────────────────────
// Foydalanuvchi kayfiyatiga qarab reja
// ─────────────────────────────────────────
function getPlanByMood(mood) {
  var plans = {
    nostalgic: {
      style: 'nostalgic', effects: ['ken_burns','vignette','grain'],
      zoom: 'in', pan: 'center', duration: 12,
      description: 'Nostaljik xotira video', mood: 'Nostaljik'
    },
    dramatic: {
      style: 'dramatic', effects: ['ken_burns','vignette','letterbox'],
      zoom: 'in', pan: 'left', duration: 10,
      description: 'Dramatik kino uslub', mood: 'Dramatik'
    },
    happy: {
      style: 'happy', effects: ['ken_burns','vignette'],
      zoom: 'out', pan: 'center', duration: 8,
      description: 'Baxtli va yorqin', mood: 'Baxtli'
    },
    cinema: {
      style: 'cinema', effects: ['ken_burns','vignette','letterbox'],
      zoom: 'in', pan: 'right', duration: 12,
      description: 'Kinematik uslub', mood: 'Kino'
    },
    memorial: {
      style: 'memorial', effects: ['ken_burns','vignette','grain','heartbeat'],
      zoom: 'in', pan: 'center', duration: 15,
      description: 'Xotira video', mood: 'Eslatma'
    }
  };
  return plans[mood] || getDefaultPlan();
}

function getDefaultPlan(prompt) {
  return {
    style:         'warm',
    effects:       ['ken_burns', 'vignette'],
    zoom:          'in',
    pan:           'center',
    duration:      10,
    text:          '',
    text_position: 'bottom',
    description:   prompt || 'Chiroyli video',
    mood:          'Ijobiy'
  };
}

module.exports = {
  analyzeImageForVideo,
  getPlanByMood,
  getDefaultPlan
};
