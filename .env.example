# ═══════════════════════════════════════════
# Individual AI Bot — .env sozlamalari
# ═══════════════════════════════════════════
# Ko'chirish: cp .env.example .env
# Keyin .env ni to'ldiring

# ── TELEGRAM BOTLAR ──
SUPER_ADMIN_BOT_TOKEN=         # Admin panel boti tokeni (@BotFather dan)
INDIVIDUAL_BOT_TOKEN=          # Asosiy foydalanuvchi boti tokeni (@BotFather dan)
#
# Muhim: INDIVIDUAL_BOT_TOKEN ni .env ga yozgandan so'ng,
# uni MongoDB ga ham saqlash kerak (bir marta):
#
#   db.userbots.insertOne({
#     botToken:        "<INDIVIDUAL_BOT_TOKEN>",
#     botUsername:     "sizning_bot_username",
#     botName:         "AI Yordamchi",
#     ownerTelegramId: "<SUPER_ADMIN_ID>",
#     ownerName:       "Ismingiz",
#     isActive:        true,
#     currentPlan:     "free",
#     allowedUsers:    [],
#     maxUsers:        50,
#     language:        "uz",
#     personality:     "friendly",
#     topics:          [],
#     extraInstructions: "",
#     userTitle:       "do'stim",
#     totalMessages:   0,
#     monthlyReset:    ""
#   })

# ── ADMIN SOZLAMALARI ──
SUPER_ADMIN_ID=                # Adminning Telegram ID si (raqam, @userinfobot dan olish mumkin)
ADMIN_USERNAME=                # Adminning @username (@ belgisiz, masalan: myusername)

# ── TO'LOV ──
CARD_NUMBER=8600 XXXX XXXX XXXX   # To'lov karta raqami (foydalanuvchiga ko'rsatiladi)

# ── DATABASE ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ── AI PROVAYDERLAR (kamida bittasi bo'lishi kerak) ──

# WisGate — birinchi navbat (barcha modellar, OpenAI-compatible)
WISGATE_API_KEYS=              # vergul bilan: key1,key2
WISGATE_BASE_URL=              # https://your-wisgate-endpoint.com
WISGATE_MODEL=deepseek-v3      # asosiy model nomi

# DeepSeek — 2-chi navbat
DEEPSEEK_API_KEY=              # vergul bilan: key1,key2

# OpenAI — 3-chi navbat
OPENAI_API_KEY=                # vergul bilan: key1,key2

# Groq — 4-chi navbat (tez va bepul)
GROQ_API_KEY=                  # vergul bilan: key1,key2,key3

# OpenRouter — 5-chi navbat (bepul modellar)
OPENROUTER_API_KEY=            # vergul bilan: key1,key2

# Gemini — 6-chi navbat (zaxira)
GEMINI_API_KEY=                # vergul bilan: key1,key2,key3
